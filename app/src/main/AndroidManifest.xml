<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Keep playing with the screen off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Foreground service so playback survives in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Show the media notification (Android 13+ asks at runtime). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Ask the system to stop killing us for "battery optimization" so long audiobooks
         are not cut off while in the background. Requested at runtime from Settings. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Optional in-app donation tips via Google Play Billing. (The billing library also
         declares this, but we list it explicitly for clarity.) -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <application
        android:name=".BrontoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.BrontoPlayer"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|fontScale"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.BrontoPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Background-capable media playback service. Media3 promotes this to a
             foreground service (type mediaPlayback) automatically while playing. -->
        <!-- A MediaSessionService must be exported so the system and external media controllers
             (e.g. Android Auto, Assistant, the system media controls) can bind to it. -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

    </application>

</manifest>
